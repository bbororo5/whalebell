# Postgres 연결 문자열 (필수)
# - 로컬: Docker 컨테이너 예) postgresql://whalebell:whalebell@localhost:5433/whalebell?schema=public
# - 배포: Neon/Supabase/Vercel Postgres 등에서 발급한 연결 문자열
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public"

# 휴대폰 번호 보호 (필수)
# PHONE_ENC_KEY: 32바이트 키 (base64 44자 또는 hex 64자). 예: openssl rand -base64 32
# PHONE_HASH_SECRET: 조회용 해시 시크릿 (임의 문자열)
PHONE_ENC_KEY="BASE64_32BYTE_KEY"
PHONE_HASH_SECRET="RANDOM_SECRET"

# Cron 보호 (Vercel Cron에서 Authorization: Bearer 로 전달)
CRON_SECRET="RANDOM_SECRET"

# (선택) 실제 문자 발송(SOLAPI). 셋 다 있어야 실제 발송, 아니면 미리보기(preview_only)만.
# SOLAPI_API_KEY=
# SOLAPI_API_SECRET=
# SOLAPI_SENDER=01000000000
