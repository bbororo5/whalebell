// 고래벨 데이터 모델 (Postgres). 배포처 무관(Vercel/Neon/장시간 서버 모두 지원).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A의 산출물 / B의 필터. 1코인 1구독.
/// 휴대폰 번호는 평문 저장하지 않는다: phoneHash(조회용 HMAC) + phoneEnc(AES-GCM 암호문).
model Subscription {
  id           String   @id @default(cuid())
  phoneHash    String
  phoneEnc     String
  coinSymbol   String
  thresholdId  String
  thresholdKrw Float
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  alerts       Alert[]

  @@unique([phoneHash, coinSymbol])
  @@index([phoneHash])
}

/// B의 산출물. (transferId, subscriptionId)로 멱등.
model Alert {
  id             String       @id @default(cuid())
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subscriptionId String
  transferId     String
  phoneHash      String
  phoneEnc       String
  coinSymbol     String
  fiatKrw        Float
  tokenAmount    Float
  direction      String
  impactLevel    String
  message        String
  shortBody      String
  delivery       String
  detectedAt     DateTime
  createdAt      DateTime     @default(now())

  @@unique([transferId, subscriptionId])
  @@index([phoneHash])
}
