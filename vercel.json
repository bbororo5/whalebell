{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": [
    "icn1"
  ],
  "services": {
    "whalebell": {
      "root": ".",
      "framework": "nextjs"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "whalebell"
      }
    }
  ]
}
